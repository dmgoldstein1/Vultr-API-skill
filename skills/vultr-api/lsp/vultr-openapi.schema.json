{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/vultr-openapi.schema.json",
  "title": "Vultr OpenAPI Profile",
  "description": "Editor/LSP profile for Vultr API OpenAPI documents.",
  "allOf": [
    {
      "$ref": "https://spec.openapis.org/oas/3.0/schema/2021-09-28"
    },
    {
      "type": "object",
      "required": ["servers", "components"],
      "properties": {
        "servers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              }
            },
            "required": ["url"]
          }
        },
        "components": {
          "type": "object",
          "required": ["securitySchemes"],
          "properties": {
            "securitySchemes": {
              "type": "object",
              "required": ["API Key"],
              "properties": {
                "API Key": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "const": "http"
                    },
                    "scheme": {
                      "const": "bearer"
                    }
                  },
                  "required": ["type", "scheme"]
                }
              }
            }
          }
        }
      }
    }
  ]
}
